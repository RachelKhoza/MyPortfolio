---
import { githubProfileUrl } from '../data/devopsProjects';
---

<section id="contact" class="container-page py-24 border-t border-ink-800/60">
  <p class="section-eyebrow">// contact</p>
  <h2 class="section-heading mb-3">Let's talk.</h2>
  <p class="text-ink-300 max-w-2xl mb-10">
    Best for Lead, Principal or Staff Cloud Security / DevSecOps roles. Open to remote globally;
    based in Johannesburg.
  </p>

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
    <a
      href="mailto:mrsrachelkhoza@gmail.com"
      class="card group"
    >
      <p class="font-mono text-xs uppercase tracking-wider text-accent mb-2">Email</p>
      <p class="text-ink-50 text-sm font-medium group-hover:text-accent transition break-all">
        mrsrachelkhoza@gmail.com
      </p>
    </a>
    <a
      href="https://www.linkedin.com/in/rachel-m-k-06523064/"
      target="_blank" rel="noopener"
      class="card group"
    >
      <p class="font-mono text-xs uppercase tracking-wider text-accent mb-2">LinkedIn</p>
      <p class="text-ink-50 text-sm font-medium group-hover:text-accent transition break-all">
        /in/rachel-m-k
      </p>
    </a>
    <a
      href={githubProfileUrl}
      target="_blank" rel="noopener"
      class="card group"
    >
      <p class="font-mono text-xs uppercase tracking-wider text-accent mb-2">GitHub</p>
      <p class="text-ink-50 text-sm font-medium group-hover:text-accent transition break-all">
        /RachelKhoza
      </p>
    </a>
    <a
      href="/devops-projects/"
      class="card group"
    >
      <p class="font-mono text-xs uppercase tracking-wider text-accent mb-2">Projects</p>
      <p class="text-ink-50 text-sm font-medium group-hover:text-accent transition">
        DevOps & DevSecOps portfolio
      </p>
    </a>
  </div>
</section>
