---
import { githubProfileUrl } from '../data/devopsProjects';
---

<section id="github-activity" class="container-page py-20 border-t border-ink-800/60">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-8">
    <div>
      <p class="section-eyebrow">// github activity</p>
      <h2 class="section-heading mb-3">Open source activity.</h2>
      <p class="text-ink-300 max-w-2xl">
        Public commits, project work, and contribution history connected directly to my GitHub profile.
      </p>
    </div>
    <a href={githubProfileUrl} target="_blank" rel="noopener" class="btn-ghost self-start md:self-auto">
      View GitHub profile
    </a>
  </div>

  <a
    href={githubProfileUrl}
    target="_blank"
    rel="noopener"
    class="block rounded-lg border border-ink-700 bg-ink-900/70 p-4 hover:border-accent/40 transition"
  >
    <img
      src="https://ghchart.rshah.org/22d3ee/RachelKhoza"
      alt="Rachel Khoza GitHub contribution activity chart"
      loading="lazy"
      class="w-full rounded bg-ink-950 p-3"
    />
  </a>
</section>
