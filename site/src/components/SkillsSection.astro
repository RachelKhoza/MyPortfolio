---
const groups = [
  {
    label: 'Cloud & Platform',
    items: ['Azure', 'AWS', 'Multi-Cloud Landing Zones', 'Well-Architected', 'FinOps'],
  },
  {
    label: 'Security & Compliance',
    items: [
      'DevSecOps',
      'SAST / DAST',
      'IaC Security (Checkov, tfsec, Terrascan)',
      'Container Security (Trivy, Aqua)',
      'Supply Chain (SBOM, SLSA, Cosign)',
      'HashiCorp Vault',
      'IAM · Zero Trust · OIDC Federation',
      'ISO 27001 · PCI-DSS · SOC 2',
    ],
  },
  {
    label: 'Infrastructure as Code',
    items: ['Terraform', 'Ansible (AAP)', 'Helm', 'Pulumi'],
  },
  {
    label: 'CI / CD',
    items: ['GitHub Actions', 'GitLab CI', 'Jenkins', 'Azure DevOps', 'ArgoCD'],
  },
  {
    label: 'Containers & Orchestration',
    items: ['Kubernetes (EKS, AKS)', 'Docker', 'Istio'],
  },
  {
    label: 'Observability',
    items: ['Azure Monitor', 'Grafana', 'Prometheus', 'Splunk', 'ELK', 'Dynatrace'],
  },
  {
    label: 'Programming',
    items: ['Python', 'PowerShell', 'Bash', 'SQL', 'JavaScript'],
  },
];
---

<section id="skills" class="container-page py-20 border-t border-ink-800/60">
  <p class="section-eyebrow">// stack</p>
  <h2 class="section-heading mb-10">What I work with day-to-day.</h2>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {groups.map((g) => (
      <div class="card">
        <p class="font-mono text-xs uppercase tracking-wider text-accent mb-3">{g.label}</p>
        <ul class="space-y-1.5 text-sm text-ink-200">
          {g.items.map((i) => <li class="flex gap-2"><span class="text-ink-500">·</span>{i}</li>)}
        </ul>
      </div>
    ))}
  </div>
</section>
