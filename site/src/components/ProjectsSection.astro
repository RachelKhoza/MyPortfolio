---
import { featuredProjectTracks, githubProfileUrl } from '../data/devopsProjects';
---

<section id="projects" class="container-page py-20 border-t border-ink-800/60">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-10">
    <div>
      <p class="section-eyebrow">// github-ready work</p>
      <h2 class="section-heading mb-3">DevOps & DevSecOps projects.</h2>
      <p class="text-ink-300 max-w-2xl">
        Public project tracks designed to show practical DevSecOps depth: secure pipelines, cloud
        guardrails, Kubernetes hardening, code quality, container scanning, and operational response.
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/devops-projects/" class="btn-primary">View project page</a>
      <a href={githubProfileUrl} target="_blank" rel="noopener" class="btn-ghost">GitHub activity</a>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    {featuredProjectTracks.map((p) => (
      <article class="card group flex flex-col">
        <p class="font-mono text-xs text-accent uppercase tracking-wider mb-3">
          {p.stage}
        </p>
        <h3 class="text-xl font-semibold text-ink-50 mb-3 group-hover:text-accent transition">
          {p.title}
        </h3>
        <p class="text-sm text-ink-300 leading-relaxed mb-4 flex-1">{p.summary}</p>
        <p class="text-sm text-ink-200 leading-relaxed mb-5 border-l-2 border-accent pl-4">
          {p.result}
        </p>
        <div class="flex flex-wrap gap-1.5 mb-5">
          {p.stack.map((s) => <span class="chip">{s}</span>)}
        </div>
        <a
          href={`/devops-projects/#${p.id}`}
          class="inline-flex items-center gap-1.5 text-xs font-mono text-accent hover:translate-x-1 transition"
        >
          Open project scope
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </article>
    ))}
  </div>
</section>
