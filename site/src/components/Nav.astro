---
import { githubProfileUrl } from '../data/devopsProjects';

const links = [
  { href: '/#about', label: 'About' },
  { href: '/#current-projects', label: 'Current Projects' },
  { href: '/devops-projects/', label: 'DevOps Projects' },
  { href: '/blog', label: 'Blog' },
  { href: githubProfileUrl, label: 'GitHub', external: true },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-40 backdrop-blur bg-ink-950/70 border-b border-ink-800">
  <nav class="container-page flex items-center justify-between h-16">
    <a href="/" class="flex items-baseline gap-2 group">
      <span class="font-mono text-accent">~/</span>
      <span class="font-bold tracking-tight text-ink-50 group-hover:text-accent transition">rachelkhoza</span>
      <span class="font-mono text-ink-500 text-sm">.dev</span>
    </a>
    <ul class="hidden md:flex items-center gap-7 text-sm text-ink-300">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noopener' : undefined}
            class="hover:text-accent transition font-mono"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
