# Copy this file to .env and fill in real values. .env is gitignored.
# Tokens here are an example of the secret-hygiene pattern — the site itself
# doesn't currently need any of these at runtime, but the example exists so
# anyone forking sees the expected shape.

# GitLab project-scoped token (use Project → Settings → Access Tokens, NOT a PAT)
# Scopes: read_api (minimum)
GITLAB_TOKEN=

# GitHub fine-grained token if you wire in dynamic repo cards later
# Scopes: public_repo (read-only)
GITHUB_TOKEN=

# Netlify token if you script deploys later
NETLIFY_AUTH_TOKEN=
